<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Grocery.App.ViewModels"
             x:Class="Grocery.App.Views.ProductCategoriesView"
             Title="Producten in categorie">
    <StackLayout Padding="10">
        <Label Text="{Binding Category.Name}" FontSize="24" FontAttributes="Bold" />
        <CollectionView ItemsSource="{Binding AvailableProducts}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="8" Padding="8" BorderColor="LightGray">
                        <StackLayout>
                            <Label Text="{Binding Name}" FontSize="18" />
                            <Label Text="{Binding Stock}" FontSize="14" />
                        </StackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </StackLayout>
</ContentPage>
