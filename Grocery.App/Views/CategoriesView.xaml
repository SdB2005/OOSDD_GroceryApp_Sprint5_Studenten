<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Grocery.App.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Grocery.App.Views.CategoriesView"
             Title="Categorieën">
    <CollectionView x:Name="categoriesCollectionView" ItemsSource="{Binding Categories}" SelectionMode="Single">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Frame Margin="8" Padding="8" BorderColor="LightGray">
                    <Label Text="{Binding Name}" FontSize="20" />
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
        <CollectionView.Behaviors>
            <toolkit:EventToCommandBehavior EventName="SelectionChanged"
                                            Command="{Binding SelectCategoryCommand}"
                                            CommandParameter="{Binding SelectedItem, Source={x:Reference categoriesCollectionView}}" />
        </CollectionView.Behaviors>
    </CollectionView>
</ContentPage>
